{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "done": { "type": "boolean" },
    "progress_made": { "type": "boolean" },
    "summary": { "type": "string" },
    "tests_ran": { "type": "boolean" },
    "tests_status": { "type": "string", "enum": ["pass", "fail", "not_run"] },
    "next_step": { "type": "string" },
    "stop_reason": { "type": "string" }
  },
  "required": [
    "done",
    "progress_made",
    "summary",
    "tests_ran",
    "tests_status",
    "next_step",
    "stop_reason"
  ]
}
