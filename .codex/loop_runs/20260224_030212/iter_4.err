+    assert not harm_errors
+
+    pos_idx = tokens.index("POS_24")
+    found_upper = False
+    idx = pos_idx + 1
+    while idx < len(tokens) and tokens[idx] != "BAR" and not tokens[idx].startswith("POS_"):
+        if not tokens[idx].startswith("VOICE_"):
