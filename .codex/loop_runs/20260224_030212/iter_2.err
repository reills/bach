+from dataclasses import dataclass
+from typing import Iterable, Optional, Tuple
+
+MEL_INT12_MIN = -24
+MEL_INT12_MAX = 24
+HARM_OCT_MIN = -2
+HARM_OCT_MAX = 4
+
