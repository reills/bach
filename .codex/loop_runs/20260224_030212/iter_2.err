+                        harm_oct_tok != expected_harm_oct
+                        or harm_cls_tok != expected_harm_cls
+                    ):
+                        errors.append(
+                            f"Mismatch at {idx} (Voice {v_idx}, POS {pos_tick}): "
+                            f"Pitch {pitch} (Ref {ref_pitch}). Expected "
